{
  "name": "Auto Test Generation",
  "version": "1.0.0",
  "description": "Automatically generate test files when new source files are created",
  "when": {
    "type": "fileCreated",
    "patterns": ["src/**/*.ts", "src/**/*.js", "src/**/*.tsx", "src/**/*.jsx", "!**/*.test.*", "!**/*.spec.*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new source file was created. Generate a corresponding test file:\n1. Create test file with appropriate naming (.test.ts or .spec.ts)\n2. Import the module being tested\n3. Generate test structure with describe/it blocks\n4. Create tests for:\n   - Happy path scenarios\n   - Edge cases\n   - Error handling\n   - Input validation\n5. Aim for 80%+ code coverage\n6. Follow testing best practices from dev-team-standards.md\n\nGenerate comprehensive tests that are ready to run."
  }
}
