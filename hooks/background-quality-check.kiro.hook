{
  "enabled": true,
  "name": "Background Quality Check",
  "description": "Run quality checks in background after task completion",
  "version": "1",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "runCommand",
    "command": "node .kiro/scripts/background-quality-check.js &"
  }
}